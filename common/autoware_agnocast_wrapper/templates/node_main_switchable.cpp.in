#define NODE_MAIN_LOGGER_NAME "@node@"

int main(int argc, char * argv[])
{
  bool use_agnocast = autoware::agnocast_wrapper::use_agnocast();

  rclcpp::Logger logger = rclcpp::get_logger(NODE_MAIN_LOGGER_NAME);
