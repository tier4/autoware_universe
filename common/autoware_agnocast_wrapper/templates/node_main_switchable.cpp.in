    try {
      exec.spin();
    } catch (const std::exception & ex) {
      RCLCPP_ERROR(logger, "Exception during spin: %s", ex.what());
      exec.remove_node(node_wrapper->get_node_base_interface());
      rclcpp::shutdown();
      return 1;
    }

    exec.remove_node(node_wrapper->get_node_base_interface());
    rclcpp::shutdown();
  }

  // Clean up loaders
  for (auto loader : loaders) {
