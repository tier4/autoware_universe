        } catch (const std::exception & ex) {
          RCLCPP_ERROR(logger, "Failed to load library: %s", ex.what());
          return 1;
        } catch (...) {
          RCLCPP_ERROR(logger, "Failed to load library");
          return 1;
        }
        auto wrapper = node_factory->create_node_instance(options);
        node_wrapper =
