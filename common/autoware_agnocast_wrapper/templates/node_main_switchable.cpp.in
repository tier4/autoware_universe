        break;
      }
    }

    if (!node_wrapper) {
      RCLCPP_ERROR(logger, "Failed to find node class: %s", class_name.c_str());
      return 1;
    }

    // Use AgnocastOnlySingleThreadedExecutor for agnocast::Node
    agnocast::AgnocastOnlySingleThreadedExecutor exec;
    exec.add_node(node_wrapper->get_agnocast_node());

    try {
      exec.spin();
    } catch (const std::exception & ex) {
      RCLCPP_ERROR(logger, "Exception during spin: %s", ex.what());
      return 1;
    }

  } else {
