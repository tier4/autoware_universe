<launch>
  <arg name="carla_host" default="localhost"/>
  <arg name="carla_port" default="2000"/>
  <arg name="scene_yaml"/>
  <arg name="spawn_lanelet_id" default="2303321"/>
  <arg name="spawn_s" default="0.0"/>
  <arg name="vehicle_type" default="vehicle.mini.cooper_s_2021"/>
  <arg name="timeout_seconds" default="30.0"/>
  <arg name="image_topic" default="/splatsim/image_raw"/>
  <arg name="camera_info_topic" default="/splatsim/camera_info"/>
  <arg name="frame_id" default="splatsim_camera"/>

  <include file="$(find-pkg-share splatsim)/launch/splatsim_scenario.launch.xml">
    <arg name="carla_host" value="$(var carla_host)"/>
    <arg name="carla_port" value="$(var carla_port)"/>
    <arg name="scene_yaml" value="$(var scene_yaml)"/>
    <arg name="spawn_lanelet_id" value="$(var spawn_lanelet_id)"/>
    <arg name="spawn_s" value="$(var spawn_s)"/>
    <arg name="vehicle_type" value="$(var vehicle_type)"/>
    <arg name="timeout_seconds" value="$(var timeout_seconds)"/>
    <arg name="image_topic" value="$(var image_topic)"/>
    <arg name="camera_info_topic" value="$(var camera_info_topic)"/>
    <arg name="frame_id" value="$(var frame_id)"/>
  </include>
</launch>
