{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parameters for Trajectory Modifier",
  "type": "object",
  "definitions": {
    "trajectory_modifier": {
      "type": "object",
      "properties": {
        "use_stop_point_fixer": {
          "type": "boolean",
          "description": "Enable the stop point fixer modifier plugin",
          "default": true
        },
        "use_obstacle_stop": {
          "type": "boolean",
          "description": "Enable the obstacle stop modifier plugin",
          "default": true
        },
        "trajectory_time_step": {
          "type": "number",
          "description": "Time step for trajectory modification [s]",
          "default": 0.1,
          "minimum": 0.0
        },
        "stop_point_fixer": {
          "type": "object",
          "properties": {
            "velocity_threshold_mps": {
              "type": "number",
              "description": "Velocity threshold below which ego vehicle is considered stationary",
              "default": 0.1,
              "minimum": 0.0
            },
            "min_distance_threshold_m": {
              "type": "number",
              "description": "Minimum distance threshold to trigger trajectory replacement",
              "default": 1.0,
              "minimum": 0.0
            }
          },
          "required": [],
          "additionalProperties": false
        },
        "obstacle_stop": {
          "type": "object",
          "properties": {
            "use_objects": {
              "type": "boolean",
              "description": "Enable the use of objects for obstacle stop",
              "default": true
            },
            "use_pointcloud": {
              "type": "boolean",
              "description": "Enable the use of pointcloud for obstacle stop",
              "default": true
            },
            "stop_margin_m": {
              "type": "number",
              "description": "Distance to maintain from an obstacle when stopped [m]",
              "default": 6.0,
              "minimum": 0.0
            },
            "nom_stopping_decel": {
              "type": "number",
              "description": "Nominal deceleration during stopping [m/s^2]",
              "default": -2.0
            },
            "nom_stopping_jerk": {
              "type": "number",
              "description": "Nominal jerk during stopping [m/s^3]",
              "default": -3.0
            },
            "max_stopping_decel": {
              "type": "number",
              "description": "Maximum deceleration during stopping [m/s^2]",
              "default": -4.0
            },
            "max_stopping_jerk": {
              "type": "number",
              "description": "Maximum jerk during stopping [m/s^3]",
              "default": -8.0
            },
            "on_time_buffer": {
              "type": "number",
              "description": "Duration an obstacle must be detected before stopping [s]",
              "default": 0.5,
              "minimum": 0.0
            },
            "off_time_buffer": {
              "type": "number",
              "description": "Duration an obstacle must be detected before stopping [s]",
              "default": 1.0,
              "minimum": 0.0
            },
            "lateral_margin_m": {
              "type": "number",
              "description": "Lateral margin on top of ego width from trajectory to consider for obstacle stop [m]",
              "default": 0.5,
              "minimum": 0.0
            },
            "duplicate_check_threshold_m": {
              "type": "number",
              "description": "Threshold to check if the stop point is already in the trajectory [m]",
              "default": 1.0,
              "minimum": 0.0
            },
            "objects": {
              "type": "object",
              "properties": {
                "object_types": {
                  "type": "array",
                  "description": "Object types to consider for obstacle stop",
                  "default": [
                    "car",
                    "truck",
                    "bus",
                    "trailer",
                    "motorcycle",
                    "bicycle",
                    "pedestrian",
                    "unknown"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "max_velocity_th": {
                  "type": "number",
                  "description": "Maximum velocity threshold for target object [m/s]",
                  "default": 1.0,
                  "minimum": 0.0
                }
              },
              "required": [],
              "additionalProperties": false
            },
            "pointcloud": {
              "type": "object",
              "properties": {
                "height_buffer": {
                  "type": "number",
                  "description": "Height buffer to add above ego height [m]",
                  "default": 0.5,
                  "minimum": 0.0
                },
                "min_height": {
                  "type": "number",
                  "description": "Minimum height of pointcloud [m]",
                  "default": 0.2,
                  "minimum": 0.0
                },
                "detection_range": {
                  "type": "number",
                  "description": "Detection range [m]",
                  "default": 100.0,
                  "minimum": 0.0
                },
                "voxel_grid_filter": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number",
                      "description": "X dimension of voxel grid filter [m]",
                      "default": 0.2,
                      "minimum": 0.0
                    },
                    "y": {
                      "type": "number",
                      "description": "Y dimension of voxel grid filter [m]",
                      "default": 0.2,
                      "minimum": 0.0
                    },
                    "z": {
                      "type": "number",
                      "description": "Z dimension of voxel grid filter [m]",
                      "default": 0.2,
                      "minimum": 0.0
                    },
                    "min_size": {
                      "type": "number",
                      "description": "Minimum size of voxel grid filter [m]",
                      "default": 3,
                      "minimum": 0.0
                    }
                  },
                  "required": [],
                  "additionalProperties": false
                },
                "clustering": {
                  "type": "object",
                  "properties": {
                    "tolerance": {
                      "type": "number",
                      "description": "Tolerance for clustering [m]",
                      "default": 0.5,
                      "minimum": 0.0
                    },
                    "min_height": {
                      "type": "number",
                      "description": "Minimum height for clustering [m]",
                      "default": 0.5,
                      "minimum": 0.0
                    },
                    "min_size": {
                      "type": "number",
                      "description": "Minimum size for clustering [m]",
                      "default": 10,
                      "minimum": 0.0
                    },
                    "max_size": {
                      "type": "number",
                      "description": "Maximum size for clustering [m]",
                      "default": 10000,
                      "minimum": 0.0
                    }
                  },
                  "required": [],
                  "additionalProperties": false
                }
              },
              "required": [],
              "additionalProperties": false
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "required": [],
      "additionalProperties": false
    }
  },
  "properties": {
    "/**": {
      "type": "object",
      "properties": {
        "ros__parameters": {
          "$ref": "#/definitions/trajectory_modifier"
        }
      },
      "required": ["ros__parameters"],
      "additionalProperties": false
    }
  },
  "required": ["/**"],
  "additionalProperties": false
}
