<?xml version="1.0"?>
<library path="autoware_trajectory_validator_plugins">
  <class type="autoware::trajectory_validator::plugin::OutOfLaneFilter"
    base_class_type="autoware::trajectory_validator::plugin::ValidatorInterface">
    <description>
      Filters trajectories that go out of lane boundaries
    </description>
  </class>
  <class type="autoware::trajectory_validator::plugin::CollisionFilter"
    base_class_type="autoware::trajectory_validator::plugin::ValidatorInterface">
    <description>
      Filters trajectories based on Time To Collision (TTC) with predicted objects
    </description>
  </class>
  <class type="autoware::trajectory_validator::plugin::UncrossableBoundaryDepartureFilter"
    base_class_type="autoware::trajectory_validator::plugin::ValidatorInterface">
    <description>
      Filters trajectories that cross uncrossable boundaries
    </description>
  </class>
  <class type="autoware::trajectory_validator::plugin::VehicleConstraintFilter"
    base_class_type="autoware::trajectory_validator::plugin::ValidatorInterface">
    <description>
      Filters trajectories that violate vehicle constraints such as maximum speed, acceleration, and steering angle
    </description>
  </class>
  <class type="autoware::trajectory_validator::plugin::CollisionCheckFilter"
         base_class_type="autoware::trajectory_validator::plugin::ValidatorInterface">
    <description>
      Filters trajectories based on collision checks with predicted objects
    </description>
  </class>
</library>
