  </node>

  <node pkg="autoware_default_adapi" exec="routing_node" name="routing" namespace="adapi/node">
    <env name="LD_PRELOAD" value="libagnocast_heaphook.so:$(env LD_PRELOAD '')"/>
    <param from="$(var config)"/>
  </node>

  <!-- Universe ADAPI nodes -->
  <node pkg="autoware_default_adapi_universe" exec="autoware_state_node" name="autoware_state" namespace="adapi/node">
    <env name="LD_PRELOAD" value="libagnocast_heaphook.so:$(env LD_PRELOAD '')"/>
