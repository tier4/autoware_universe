<launch>
  <arg name="config" default="$(find-pkg-share autoware_default_adapi_universe)/config/default_adapi.param.yaml"/>

  <!-- Core ADAPI nodes (from autoware_default_adapi) -->
  <node pkg="autoware_default_adapi" exec="interface_node" name="interface" namespace="adapi/node">
    <env name="LD_PRELOAD" value="libagnocast_heaphook.so:$(env LD_PRELOAD '')"/>
    <param from="$(var config)"/>
  </node>

  <node pkg="autoware_default_adapi" exec="localization_node" name="localization" namespace="adapi/node">
    <env name="LD_PRELOAD" value="libagnocast_heaphook.so:$(env LD_PRELOAD '')"/>
