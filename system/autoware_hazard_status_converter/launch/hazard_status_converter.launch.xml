<launch>
  <node pkg="autoware_hazard_status_converter" exec="autoware_hazard_status_converter_agnocast_node" name="hazard_status_converter">
    <env name="LD_PRELOAD" value="/opt/ros/humble/lib/libagnocast_heaphook.so:$(env LD_PRELOAD '')"/>
    <remap from="~/diagnostics_graph" to="/diagnostics_graph"/>
    <remap from="~/hazard_status" to="/system/emergency/hazard_status"/>
    <remap from="~/input/emergency_holding" to="/system/emergency_holding"/>
  </node>
</launch>
