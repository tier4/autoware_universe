<?xml version="1.0"?>
<launch>
  <!-- Parameters -->
  <arg name="config_file" default="$(find-pkg-share autoware_pipeline_latency_monitor)/config/pipeline_latency_monitor.param.yaml"/>

  <node pkg="autoware_pipeline_latency_monitor" exec="autoware_pipeline_latency_monitor_agnocast_node" name="pipeline_latency_monitor" output="screen">
    <env name="LD_PRELOAD" value="/opt/ros/humble/lib/libagnocast_heaphook.so:$(env LD_PRELOAD '')"/>
    <param from="$(var config_file)"/>
  </node>
</launch>
